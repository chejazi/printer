# Required: bearer token for POST /print and GET /printers
AUTH_TOKEN=change-me-to-a-long-random-string

# HTTP port (default: 3000)
PORT=3000

# CUPS printer queue name (default: USB_80Series2)
PRINTER_NAME=USB_80Series2

# Batch queue: wait this long after the last message before printing (default: 500)
COALESCE_MS=500

# Pause between completed CUPS batches (default: 500)
JOB_DELAY_MS=500

# Cancel/wait timeout for a CUPS job (default: 30000)
JOB_TIMEOUT_MS=30000

# Reject new messages when this many are waiting (default: 100)
MAX_QUEUE_MESSAGES=100
